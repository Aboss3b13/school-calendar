{
  "expo": {
    "name": "SchoolFlow Planner",
    "slug": "school-calendar-app",
    "version": "1.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.aboss3b13.schoolflow",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "SchoolOverview",
              "label": "SchoolFlow Overview",
              "description": "Upcoming exam, open tasks and average grade",
              "minWidth": "250dp",
              "minHeight": "120dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "previewImage": "./assets/icon.png",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "CalendarWidget",
              "label": "SchoolFlow Calendar",
              "description": "Today and next calendar event",
              "minWidth": "220dp",
              "minHeight": "120dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "previewImage": "./assets/icon.png",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "NextTestWidget",
              "label": "SchoolFlow Next Test",
              "description": "Next upcoming test with subject and date",
              "minWidth": "220dp",
              "minHeight": "120dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "previewImage": "./assets/icon.png",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "QuickGradeWidget",
              "label": "SchoolFlow Grade",
              "description": "Official weighted average and open tasks",
              "minWidth": "180dp",
              "minHeight": "120dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "previewImage": "./assets/icon.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ]
  }
}
